doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Manage Bookings - Local Service Provider Admin
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings", class="active") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Manage Bookings
                main
                    div.filter-container(style="margin-bottom: 2rem; display:flex; gap: 1rem;")
                        input(type="date", id="date-filter", style="padding: 0.8rem;")
                        select#booking-status-filter(style="padding: 0.8rem;")
                            option(value="all") All Statuses
                            option(value="Pending") Pending
                            option(value="Confirmed") Confirmed
                            option(value="Completed") Completed
                            option(value="Cancelled") Cancelled
                    div#bookings-management-table

        script(src="/admin/admin.js")
