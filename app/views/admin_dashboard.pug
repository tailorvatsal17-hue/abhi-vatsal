doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Admin Dashboard - Local Service Provider
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard", class="active") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header(style="display: flex; justify-content: space-between; align-items: center;")
                    h1 Dashboard
                    button#generate-report-btn.button-success Generate Full Report (CSV)
                main
                    div.dashboard-stats
                        div.stat-card
                            h3 Total Users
                            p#total-users 0
                        div.stat-card
                            h3 Total Partners
                            p#total-partners 0
                        div.stat-card
                            h3 Total Services
                            p#total-services 0
                        div.stat-card
                            h3 Total Bookings
                            p#total-bookings 0
                        div.stat-card
                            h3 Total Earnings
                            p#total-earnings £0
                    div.recent-bookings
                        h2 Recent Bookings
                        div#bookings-table

        script(src="/admin/admin.js")
