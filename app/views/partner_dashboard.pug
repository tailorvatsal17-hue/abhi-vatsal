doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Partner Dashboard - Local Service Provider
        link(rel="stylesheet", href="/partner/partner.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.partner-panel
            div.sidebar
                h2 Partner Dashboard
                nav
                    ul
                        li: a(href="/partner/dashboard", class="active") Dashboard
                        li: a(href="/partner/bookings") Bookings
                        li: a(href="/partner/profile") Profile
                        li: a(href="#availability-management", id="availability-link") Availability
                        li: a(href="#", id="partner-logout-btn") Logout
            div.main-content
                header
                    h1 Dashboard
                main
                    div.dashboard-stats
                        div.stat-card
                            h3 Total Bookings
                            p#total-bookings 0
                        div.stat-card
                            h3 Pending Bookings
                            p#pending-bookings 0
                        div.stat-card
                            h3 Completed Bookings
                            p#completed-bookings 0
                        div.stat-card
                            h3 Total Earnings
                            p#total-earnings £0
                    div.recent-bookings
                        h2 Recent Booking Requests
                        div#bookings-table

                    div#availability-management.availability-section
                        h2 Manage Availability
                        form#add-availability-form.availability-form
                            label(for="available-date") Date:
                            input(type="date", id="available-date", required)

                            label(for="start-time") Start Time:
                            input(type="time", id="start-time", required)

                            label(for="end-time") End Time:
                            input(type="time", id="end-time", required)

                            button(type="submit") Add Availability

                        h3 Your Available Slots
                        div#availability-table-container.availability-table

        script(src="/partner/partner.js")
