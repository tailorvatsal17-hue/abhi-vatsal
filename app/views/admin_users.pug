doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Manage Users - Local Service Provider Admin
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users", class="active") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Manage Users
                main
                    div.search-container(style="margin-bottom: 2rem;")
                        input(type="text", id="user-search", placeholder="Search by name or email...", style="padding: 0.8rem; width: 300px;")
                    div#users-table

        script(src="/admin/admin.js")
