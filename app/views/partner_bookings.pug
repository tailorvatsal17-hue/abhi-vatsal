doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Partner Bookings - Local Service Provider
        link(rel="stylesheet", href="/partner/partner.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.partner-panel
            div.sidebar
                h2 Partner Dashboard
                nav
                    ul
                        li: a(href="/partner/dashboard") Dashboard
                        li: a(href="/partner/bookings", class="active") Bookings
                        li: a(href="/partner/profile") Profile
                        li: a(href="#", id="partner-logout-btn") Logout
            div.main-content
                header
                    h1 Booking Requests
                main
                    div.filter-container(style="margin-bottom: 2rem;")
                        select#booking-status-filter(style="padding: 0.8rem;")
                            option(value="all") All Statuses
                            option(value="Pending") Pending
                            option(value="Confirmed") Confirmed
                            option(value="Completed") Completed
                            option(value="Cancelled") Cancelled
                    div#bookings-management-table

        script(src="/partner/partner.js")
