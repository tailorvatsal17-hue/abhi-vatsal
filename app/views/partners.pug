extends layout

block content
    section.services-section
        div.container
            h2.section-title Find a Professional
            div.search-bar(style="max-width: 800px; margin: 0 auto 3rem auto;")
                form.search-form(style="box-shadow: none; border: 1px solid var(--border-color);")
                    input(type="text", placeholder="Search for professionals or locations...")
                    button(type="submit") Search
            
            div.partner-list
                if partners && partners.length > 0
                    each partner in partners
                        div.partner-item
                            - var profileImg = partner.profile_image || 'https://via.placeholder.com/300x200?text=Professional'
                            img(src=profileImg, alt=partner.name)
                            div.partner-item-content
                                h4= partner.name
                                p= partner.description
                                p: strong Pricing: #{partner.pricing}
                                p: strong Rating: #{partner.rating || 'N/A'} ⭐
                                a.button(href=`/booking?partner_id=${partner.id}&service_id=${partner.service_id}`) Book Now
                else
                    p(style="text-align: center;") No professionals found for this selection.
