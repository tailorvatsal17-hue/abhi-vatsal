extends layout

block content
    section.services-section
        div.container
            h2.section-title Find a Professional
            div.search-bar(style="max-width: 800px; margin: 0 auto 3rem auto;")
                form.search-form(style="box-shadow: none; border: 1px solid var(--border-color);")
                    input(type="text", placeholder="Search for professionals or locations...")
                    button(type="submit") Search
            
            div.partner-list
                if partners && partners.length > 0
                    each partner in partners
                        div.partner-item
                            - var profileImg = getImageUrl(partner.profile_image, 'partner')
                            img(src=profileImg, alt=partner.name, style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px;")
                            div.partner-item-content
                                h4= partner.name
                                p(style="color: #666; margin: 0.5rem 0;")= partner.description
                                p
                                    strong Pricing: 
                                    span= partner.pricing
                                p
                                    strong Rating: 
                                    if partner.rating && partner.rating > 0
                                        span= `${partner.rating} ⭐`
                                    else
                                        span(style="color: #999;") Not rated yet
                                if partner.is_approved
                                    a.button(href=`/booking?partner_id=${partner.id}&service_id=${partner.service_id}`) Book Now
                                else
                                    span.badge(style="color: #ff6b6b; font-size: 0.9rem;") Pending Approval
                else
                    p(style="text-align: center;") No professionals found for this selection.
