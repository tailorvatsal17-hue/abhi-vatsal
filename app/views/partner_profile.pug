doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Partner Profile - Local Service Provider
        link(rel="stylesheet", href="/partner/partner.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.partner-panel
            div.sidebar
                h2 Partner Dashboard
                nav
                    ul
                        li: a(href="/partner/dashboard") Dashboard
                        li: a(href="/partner/bookings") Bookings
                        li: a(href="/partner/profile", class="active") Profile
                        li: a(href="#", id="partner-logout-btn") Logout
            div.main-content
                header
                    h1 Manage Profile
                main
                    div.form-container(style="max-width: 800px; margin: 0 auto; background-color: #fff; padding: 2rem; border-radius: 10px; box-shadow: var(--shadow);")
                        h3 Profile Details
                        form#partner-profile-form
                            div.form-group
                                label(for="profile-name") Full Name
                                input(type="text", id="profile-name", required)
                            div.form-group
                                label(for="profile-email") Email
                                input(type="email", id="profile-email", disabled)
                            div.form-group
                                label(for="profile-description") Work Description / Experience
                                textarea(id="profile-description", required)
                            div.form-group
                                label(for="profile-pricing") Pricing (e.g., "£50/hour, £100 for a specific job")
                                input(type="text", id="profile-pricing", required)
                            div.form-group
                                label(for="profile-image-url") Profile Image URL or Path
                                input(type="text", id="profile-image-url", placeholder="/images/partners/your-name.jpg")
                                p(style="font-size: 0.85rem; color: #666; margin-top: 0.5rem;") Example: /images/partners/profile.jpg or https://example.com/image.jpg
                            div.form-group
                                label(for="work-images-url") Work Images URLs/Paths (comma separated)
                                textarea(id="work-images-url", placeholder="/images/partners/work1.jpg, /images/partners/work2.jpg")
                                p(style="font-size: 0.85rem; color: #666; margin-top: 0.5rem;") Example: /images/partners/work1.jpg, /images/partners/work2.jpg
                            
                            div#profile-images-preview(style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;")
                                h4 Profile Image Preview
                                div#profile-image-preview(style="margin-bottom: 2rem;")
                                    img(id="profile-img-display", style="width: 200px; height: 200px; object-fit: cover; border-radius: 8px; background: #f0f0f0;")
                                
                                h4 Work Images Preview
                                div#work-images-preview(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1rem;")
                                    // Work images will be populated by JavaScript

                            button(type="submit", class="button") Update Profile

        script(src="/partner/partner.js")
        script.
            // Helper function to get image URL
            function getImageUrl(imageUrl, type = 'partner') {
              const fallbacks = {
                partner: 'https://via.placeholder.com/200x200?text=Profile',
                work: 'https://via.placeholder.com/150x150?text=Portfolio'
              };
              
              if (!imageUrl || imageUrl.trim() === '') {
                return fallbacks[type] || fallbacks.partner;
              }
              
              if (imageUrl.startsWith('/') || imageUrl.startsWith('http')) {
                return imageUrl;
              }
              
              return '/' + imageUrl;
            }
            
            // Update preview images when form inputs change
            document.getElementById('profile-image-url').addEventListener('change', (e) => {
              const imgUrl = getImageUrl(e.target.value, 'partner');
              document.getElementById('profile-img-display').src = imgUrl;
            });
            
            document.getElementById('work-images-url').addEventListener('change', (e) => {
              const preview = document.getElementById('work-images-preview');
              preview.innerHTML = '';
              
              const images = e.target.value.split(',').map(img => img.trim()).filter(img => img);
              images.forEach((img, idx) => {
                const imgUrl = getImageUrl(img, 'work');
                const div = document.createElement('div');
                div.style.textAlign = 'center';
                const imgEl = document.createElement('img');
                imgEl.src = imgUrl;
                imgEl.style.width = '100%';
                imgEl.style.height = '150px';
                imgEl.style.objectFit = 'cover';
                imgEl.style.borderRadius = '8px';
                imgEl.alt = `Work image ${idx + 1}`;
                div.appendChild(imgEl);
                preview.appendChild(div);
              });
            });

