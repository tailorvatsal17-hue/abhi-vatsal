# Use Node.js 18 Alpine (lightweight, stable, widely supported)
FROM node:18-alpine

# Set working directory
WORKDIR /src

# Copy package files
COPY package*.json /src/

# Install supervisor globally for auto-reload in development
# Then install npm dependencies
RUN npm install -g supervisor && npm install

# Copy all application files
COPY . /src

# Expose port 3000
EXPOSE 3000

# Default command (overridden by docker-compose)
CMD ["supervisor", "-e", "js,pug,html", "index.js"]
