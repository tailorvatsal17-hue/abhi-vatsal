# Environment Configuration Template

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=secure_app_password_here
DB_NAME=lsp_database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345
JWT_EXPIRATION=86400

# Email Configuration (Gmail with App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password-here

# Server Configuration
PORT=3000
NODE_ENV=development

# Admin Configuration (optional - for initial setup only)
# Once admin exists in database, remove these
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=bcrypt_hashed_password_here
