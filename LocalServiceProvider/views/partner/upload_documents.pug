extends partner_layout

block content
    div.table-card(style="max-width: 600px; margin-bottom: 2rem;")
        div.table-header
            h2 <i class="fas fa-file-upload"></i> Upload Verification Documents
        div(style="padding: 1.5rem;")
            p(style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;") Upload your ID proof and professional certificates for account verification. Trusted partners get more bookings!
            
            form#upload-doc-form(enctype="multipart/form-data")
                div.form-group
                    label(for="document-type") Document Category
                    select#document-type(name="document_type", required)
                        option(value="ID Proof") ID Proof (Passport/License)
                        option(value="Professional Certificate") Professional Certificate
                        option(value="Business License") Business License
                        option(value="Insurance") Insurance Document
                
                div.form-group
                    label(for="document") Select File (PDF, JPG, PNG - Max 5MB)
                    input#document(type="file", name="document", accept=".pdf,.jpg,.jpeg,.png", required)
                
                button.button.button-primary(type="submit", style="width: 100%;") 
                    i.fas.fa-upload
                    span Upload Document

    div.table-card
        div.table-header
            h2 <i class="fas fa-shield-alt"></i> Verification Status
        div.table-responsive
            div#docs-table-container
                p.text-center(style="padding: 2rem;") Loading documents...
