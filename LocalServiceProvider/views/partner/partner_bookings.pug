extends partner_layout

block content
    div.table-card
        div.table-header
            h2 <i class="fas fa-calendar-alt"></i> Booking Requests
            div.filter-container
                select#booking-status-filter(style="padding: 0.5rem; border-radius: 0.5rem; border: 1px solid var(--border-color);")
                    option(value="all") All Statuses
                    option(value="Pending") Pending
                    option(value="Accepted") Accepted
                    option(value="In Progress") In Progress
                    option(value="Paid") Paid
                    option(value="Completed") Completed
                    option(value="Cancelled") Cancelled
                    option(value="Rejected") Rejected
        div.table-responsive
            div#bookings-management-table
                p.text-center(style="padding: 2rem;") Loading booking requests...

    div#chat-modal.modal
        div.modal-content
            span.close-modal#close-chat-modal &times;
            h2 <i class="fas fa-comments"></i> Chat with Customer
            div#partner-chat-window(style="height: 400px; overflow-y: auto; border: 1px solid var(--border-color); padding: 1.5rem; background: #f8fafc; border-radius: 0.75rem; margin: 1.5rem 0; display: flex; flex-direction: column; gap: 1rem;")
                p.text-center(style="color: var(--text-muted);") Select a booking to start chatting...
            form#partner-chat-form(style="display: flex; gap: 0.75rem;")
                input#partner-chat-message(type="text", placeholder="Type your message...", required, style="flex-grow: 1; padding: 0.75rem 1rem; border-radius: 0.5rem; border: 1px solid var(--border-color); outline: none;")
                button.button.button-primary(type="submit") <i class="fas fa-paper-plane"></i>
