doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Manage Partners - Local Service Provider Admin
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners", class="active") Partners
                        li: a(href="/admin/withdrawals") Withdrawals
                        li: a(href="/admin/payments") Payments
                        li: a(href="/admin/categories") Categories
                        li: a(href="/admin/disputes") Disputes
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Manage Service Partners
                main
                    div.filter-container(style="margin-bottom: 2rem;")
                        select#partner-status-filter(style="padding: 0.8rem;")
                            option(value="all") All
                            option(value="approved") Approved
                            option(value="pending") Pending Approval
                    div#partners-table

        div#partner-modal.modal
            div.modal-content
                span.close-modal &times;
                h2#modal-partner-name Partner Details
                div#modal-partner-content
                    img#modal-partner-image.partner-profile-img(src="", alt="Partner Profile", style="display:none;")
                    form#edit-partner-form
                        input(type="hidden", id="modal-partner-id")
                        div.partner-details-grid
                            div Email:
                            div#modal-partner-email
                            div Service ID:
                            div#modal-partner-service
                            div Rating:
                            div#modal-partner-rating
                            div Status:
                            div#modal-partner-status
                            
                            div Description:
                            textarea#modal-partner-description-edit(style="width: 100%; height: 80px; padding: 0.5rem; border-radius: 5px; border: 1px solid #ccc;")
                            
                            div Pricing:
                            input(type="text", id="modal-partner-pricing-edit", style="width: 100%; padding: 0.5rem; border-radius: 5px; border: 1px solid #ccc;")
                        
                        div#modal-partner-docs(style="margin-top: 2rem; border-top: 1px solid #eee; padding-top: 1rem;")
                            h3 Verification Documents
                            div#modal-docs-list
                                p Loading documents...
                        
                        div#modal-actions(style="margin-top: 2rem;")
                            button(type="submit", class="button-success") Save Changes

        script(src="/admin/admin.js")
