doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Manage Withdrawals - Admin
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/withdrawals", class="active") Withdrawals
                        li: a(href="/admin/payments") Payments
                        li: a(href="/admin/categories") Categories
                        li: a(href="/admin/disputes") Disputes
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Withdrawal Requests
                main
                    div.withdrawals-management
                        p Review and process withdrawal requests from service providers.
                        div#withdrawals-table-container
                            p Loading requests...

        script(src="/admin/admin.js")
