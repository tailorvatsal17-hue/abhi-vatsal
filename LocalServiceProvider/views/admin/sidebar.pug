        ul
            li: a(href="/admin/analytics", class=(title === "Analytics" ? "active" : "")) <i class="fas fa-chart-line"></i> View Analytics
        
        div.sidebar-section-title System
        ul
            li: a(href="#", id="admin-logout-btn") <i class="fas fa-sign-out-alt"></i> Logout
