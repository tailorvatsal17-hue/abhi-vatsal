doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Manage Payments - Admin
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/withdrawals") Withdrawals
                        li: a(href="/admin/payments", class="active") Payments
                        li: a(href="/admin/categories") Categories
                        li: a(href="/admin/disputes") Disputes
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Payment Tracking
                main
                    div.dashboard-stats(style="margin-bottom: 2rem;")
                        div.stat-card
                            h3 Total Revenue
                            p#summary-total-revenue £0
                        div.stat-card
                            h3 Successful Payments
                            p#summary-success-count 0
                        div.stat-card
                            h3 Failed Payments
                            p#summary-failed-count 0
                        div.stat-card
                            h3 Pending Payments
                            p#summary-pending-count 0

                    div.payments-management
                        h2 Transaction History
                        div#payments-table-container
                            p Loading transactions...

        script(src="/admin/admin.js")
