doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Analytics - Admin Dashboard
        link(rel="stylesheet", href="/admin/admin.css")
        link(rel="stylesheet", href="/css/style.css")
        script(src="https://cdn.jsdelivr.net/npm/chart.js")
    body
        div.admin-panel
            div.sidebar
                h2 Local Service Provider Admin
                nav
                    ul
                        li: a(href="/admin/dashboard") Dashboard
                        li: a(href="/admin/users") Users
                        li: a(href="/admin/partners") Partners
                        li: a(href="/admin/withdrawals") Withdrawals
                        li: a(href="/admin/payments") Payments
                        li: a(href="/admin/categories") Categories
                        li: a(href="/admin/disputes") Disputes
                        li: a(href="/admin/analytics", class="active") Analytics
                        li: a(href="/admin/services") Services
                        li: a(href="/admin/bookings") Bookings
                        li: a(href="#", id="admin-logout-btn") Logout
            div.main-content
                header
                    h1 Platform Analytics
                main
                    div.dashboard-stats(style="margin-bottom: 2rem;")
                        div.stat-card
                            h3 Total Revenue
                            p#analytics-revenue £0
                        div.stat-card
                            h3 Total Bookings
                            p#analytics-bookings 0
                        div.stat-card
                            h3 Total Users
                            p#analytics-users 0
                    
                    div.charts-grid(style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 2rem;")
                        div.chart-container(style="background: #fff; padding: 1.5rem; border-radius: 10px; box-shadow: var(--shadow);")
                            h3 Booking Trends (Last 30 Days)
                            canvas#bookingTrendChart
                        
                        div.chart-container(style="background: #fff; padding: 1.5rem; border-radius: 10px; box-shadow: var(--shadow);")
                            h3 Revenue Growth
                            canvas#revenueTrendChart

                        div.chart-container(style="background: #fff; padding: 1.5rem; border-radius: 10px; box-shadow: var(--shadow);")
                            h3 Booking Status Distribution
                            canvas#statusDistChart

        script(src="/admin/admin.js")
