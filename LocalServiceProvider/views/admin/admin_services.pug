extends admin_layout

block content
    div.admin-table-container(style="margin-bottom: 3rem;")
        h3 <i class="fas fa-plus-circle"></i> Add New Service
        form#add-service-form(style="margin-top: 1.5rem;")
            div.form-grid(style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;")
                div.form-group
                    label Service Name
                    input(type="text", id="service-name", placeholder="e.g. Home Cleaning", required, style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);")
                div.form-group
                    label Category
                    select#service-category(name="category_id", required, style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);")
                        option(value="") Select Category...
                        if categories
                            each cat in categories
                                option(value=cat.id)= cat.name
            div.form-group(style="margin-bottom: 1.5rem;")
                label Description
                input(type="text", id="service-desc", placeholder="Brief description of the service", style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);")
            div.form-group(style="margin-bottom: 1.5rem;")
                label Image URL (Optional)
                input(type="text", id="service-image", placeholder="https://example.com/image.jpg", style="width: 100%; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--border-color);")
            button(type="submit", class="button button-success") <i class="fas fa-plus"></i> Create Service
    
    div.admin-table-container
        h3 <i class="fas fa-list"></i> Existing Services
        div#services-table(style="margin-top: 1.5rem;")
            if services && services.length > 0
                table
                    thead
                        tr
                            th ID
                            th Name
                            th Category
                            th Description
                            th Actions
                    tbody
                        each service in services
                            tr
                                td= service.id
                                td= service.name
                                td= service.category_name || 'N/A'
                                td= service.description
                                td
                                    button.button.button-danger.button-sm(onclick=`if(confirm('Delete service?')) fetch('/api/admin/services/${service.id}', {method:'DELETE', headers:{'Authorization':'Bearer '+localStorage.getItem('adminToken')}}).then(res=>location.reload())`) 
                                        i.fas.fa-trash
            else
                p.text-center No services found.
