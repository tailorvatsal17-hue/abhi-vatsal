extends layout

block content
    section.services-section
        div.container
            h2.section-title All Services
            p.section-subtitle(style="text-align: center; margin-bottom: 3rem;") Browse our full range of professional home and business services.
            
            div.services-grid(style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 2rem;")
                if services && services.length > 0
                    each service in services
                        div.service-card(style="background: #fff; padding: 2rem; border-radius: 10px; box-shadow: var(--shadow); text-align: center; border: 1px solid var(--border-color); transition: transform 0.3s;")
                            - var icon = service.image || `https://img.icons8.com/fluency/80/000000/maintenance.png`
                            img(src=icon, alt=service.name, style="width: 70px; margin-bottom: 1rem;")
                            div.category-badge(style="font-size: 0.75rem; text-transform: uppercase; color: var(--primary-color); font-weight: 600; margin-bottom: 0.5rem;")= service.category_name
                            h3(style="margin-bottom: 0.5rem;")= service.name
                            p(style="color: #666; font-size: 0.9rem; margin-bottom: 1.5rem; height: 3.6rem; overflow: hidden;")= service.description
                            p.price(style="font-weight: bold; font-size: 1.1rem; color: var(--text-color); margin-bottom: 1.5rem;") From £#{service.base_price}
                            a.button(href=`/partners?service_id=${service.id}`, style="display: block;") View Professionals
                else
                    p(style="text-align: center; grid-column: 1 / -1;") No services found in our database.
