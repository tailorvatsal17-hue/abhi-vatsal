extends layout

block content
    section.partners-search-section
        //- Title moves OUTSIDE container for center alignment if needed, or kept inside for padding
        div.container
            h2.section-title Find Local Professionals

        //- Search Header moves OUTSIDE the container to allow 92% width
        div.top-search-header(style="width: 92%; margin: 0 auto 3rem auto;")
            div.search-bar-container(style="width: 100%;")
                form.search-form(id="partners-search-form")
                    i.fas.fa-search
                    input(type="text", placeholder="What service are you looking for? (e.g. Plumbing, Cleaning)", id="search-input")
                    button(type="submit") Search

        div.container
            div.partners-page-layout
                //- LEFT: Filter Sidebar
                aside.filter-sidebar
                    h3
                        i.fas.fa-sliders-h
                        | Filter Results
                    
                    form.filter-form
                        div.filter-group
                            label Category
                            select#filter-category
                                option(value="") All Categories
                                if categories
                                    each cat in categories
                                        option(value=cat.id)= cat.name
                        
                        button.button(type="button", id="apply-filters") Apply Filters
                        button(type="button", id="reset-filters") Reset

                //- RIGHT: Results Grid
                div.partner-results-area
                    div.results-info
                        p#results-count
                    
                    div.partner-grid(id="partner-list")
                        if partners && partners.length > 0
                            each partner in partners
                                div.partner-card-new
                                    - 
                                        var proMap = {
                                            'plumb': 'https://images.unsplash.com/photo-1607472586893-edb57cbceb42?w=500&h=500&fit=crop',
                                            'electric': 'https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=500&h=500&fit=crop',
                                            'clean': 'https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=500&h=500&fit=crop',
                                            'paint': 'https://images.unsplash.com/photo-1589939705384-5185137a7f0f?w=500&h=500&fit=crop',
                                            'pest': 'https://images.unsplash.com/photo-1599598425947-3300262b704c?w=500&h=500&fit=crop',
                                            'hvac': 'https://images.unsplash.com/photo-1621905252507-b35492d90fa6?w=500&h=500&fit=crop',
                                            'carpentr': 'https://images.unsplash.com/photo-1533090161767-e6ffed986c88?w=500&h=500&fit=crop',
                                            'appliance': 'https://images.unsplash.com/photo-1581578731522-a2047a2aa988?w=500&h=500&fit=crop'
                                        };
                                        var catKey = (partner.category_name || '').toLowerCase();
                                        var matched = Object.keys(proMap).find(k => catKey.includes(k));
                                        var defaultProImg = 'https://images.unsplash.com/photo-1581578731522-a2047a2aa988?q=80&w=500&auto=format&fit=crop';
                                        var profileImg = (partner.profile_image && partner.profile_image.includes('http')) ? partner.profile_image : (matched ? proMap[matched] : defaultProImg);
                                    div.card-image-wrapper
                                        img(src=profileImg, alt=partner.name, style="width: 100%; height: 200px; object-fit: cover;")
                                        div.rating-badge
                                            i.fas.fa-star
                                            | #{partner.rating ? parseFloat(partner.rating).toFixed(1) : 'New'}
                                    
                                    div.card-content
                                        h4= partner.partner_name || partner.name
                                        div.service-category-tag= partner.category_name || 'Professional'
                                        p= partner.description || 'Experienced professional dedicated to delivering exceptional results for all your service needs.'
                                        
                                        div.card-footer
                                            div.pricing-info
                                                span FROM
                                                div.price-value £#{partner.pricing}
                                            
                                            div.card-actions
                                                a.button(href=`/booking?partner_id=${partner.id}&service_id=${partner.service_id}`) Book
                        else
                            div.no-results
                                div.icon 🕵️‍♂️
                                h3 No professionals found
                                p Try adjusting your filters or search terms.
